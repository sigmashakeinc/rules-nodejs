# nodejs_write_safety.rules
# Technology: nodejs | Capability: write

rule nodejs-block-eval {
  enabled true
  priority 100
  severity error
  DENY write
  IF path GLOB "**/*.js" AND content CONTAINS "eval("
  OR path GLOB "**/*.ts" AND content CONTAINS "eval("
  MESSAGE "Using 'eval()' is extremely dangerous in Node.js as it can execute arbitrary code. Avoid using eval completely."
}

rule nodejs-warn-child-process-exec {
  enabled true
  priority 90
  severity warning
  LOG write
  IF path GLOB "**/*.js" AND content LINE_REGEX "child_process\\.exec\\("
  OR path GLOB "**/*.ts" AND content LINE_REGEX "child_process\\.exec\\("
  MESSAGE "Using 'child_process.exec' opens up command injection vulnerabilities if user input is included. Use 'child_process.execFile' or 'child_process.spawn' with an array of arguments instead."
}

rule nodejs-warn-prototype-pollution {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.js" AND content LINE_REGEX "\\b__proto__\\s*="
  OR path GLOB "**/*.ts" AND content LINE_REGEX "\\b__proto__\\s*="
  MESSAGE "Directly modifying the '__proto__' property can lead to Prototype Pollution, which attackers use to manipulate object properties application-wide, leading to logic bypass or Remote Code Execution (RCE). Do not mutate prototypes directly."
}

rule nodejs-warn-insecure-cookie {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*.js" AND content LINE_REGEX "res\\.cookie\\(.*?\\)" AND content NOT CONTAINS "httpOnly"
  OR path GLOB "**/*.ts" AND content LINE_REGEX "res\\.cookie\\(.*?\\)" AND content NOT CONTAINS "httpOnly"
  MESSAGE "Cookies without the 'httpOnly: true' flag can be accessed by client-side JavaScript, exposing them to Cross-Site Scripting (XSS) attacks."
}
